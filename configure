#!/bin/sh

# scLean configure script
# Detects HDF5 via Rhdf5lib and sets up compilation flags

HDF5_INCLUDE=`${R_HOME}/bin/Rscript -e "cat(system.file('include', package='Rhdf5lib'))" 2>/dev/null`
HDF5_CXX_LIBS=`${R_HOME}/bin/Rscript -e "cat(Rhdf5lib::pkgconfig('PKG_CXX_LIBS'))" 2>/dev/null`
HDF5_C_LIBS=`${R_HOME}/bin/Rscript -e "cat(Rhdf5lib::pkgconfig('PKG_C_LIBS'))" 2>/dev/null`

# Check for OpenMP (gcc-style)
OPENMP_CXXFLAGS=""
OPENMP_LIBS=""
if echo '#include <omp.h>' | ${CXX} -fopenmp -x c++ -c - -o /dev/null 2>/dev/null; then
    OPENMP_CXXFLAGS='$(SHLIB_OPENMP_CXXFLAGS)'
    OPENMP_LIBS='$(SHLIB_OPENMP_CXXFLAGS)'
elif echo '#include <omp.h>' | ${CXX} -Xclang -fopenmp -x c++ -c - -o /dev/null 2>/dev/null; then
    OPENMP_CXXFLAGS='$(SHLIB_OPENMP_CXXFLAGS)'
    OPENMP_LIBS='$(SHLIB_OPENMP_CXXFLAGS)'
fi

# Add macOS Homebrew library paths if they exist
EXTRA_LIBS=""
if [ `uname` = "Darwin" ]; then
    for libdir in /opt/homebrew/opt/openssl@3/lib /opt/homebrew/opt/curl/lib /opt/homebrew/lib /usr/local/opt/openssl@3/lib /usr/local/opt/curl/lib /usr/local/lib; do
        if [ -d "$libdir" ]; then
            EXTRA_LIBS="${EXTRA_LIBS} -L${libdir}"
        fi
    done
fi

# Find all .cpp files in subdirectories (R only auto-compiles src/*.cpp)
SUBDIR_SOURCES=`find src -mindepth 2 -name '*.cpp' 2>/dev/null`
SUBDIR_OBJECTS=`echo "$SUBDIR_SOURCES" | sed 's|^src/||; s|\.cpp$|.o|' | tr '\n' ' '`
TOP_OBJECTS="rcpp_exports.o RcppExports.o"
ALL_OBJECTS="${TOP_OBJECTS} ${SUBDIR_OBJECTS}"

# Write Makevars
cat > src/Makevars << EOF
PKG_CXXFLAGS = ${OPENMP_CXXFLAGS} -I. -I${HDF5_INCLUDE}
PKG_LIBS = ${HDF5_CXX_LIBS} ${OPENMP_LIBS} ${EXTRA_LIBS} -lz
OBJECTS = ${ALL_OBJECTS}
EOF

echo "scLean configure: HDF5 flags detected"
echo "  HDF5 include: ${HDF5_INCLUDE}"
echo "  CXX_LIBS:     ${HDF5_CXX_LIBS}"
echo "  C_LIBS:       ${HDF5_C_LIBS}"
echo "  OpenMP:       ${OPENMP_CXXFLAGS:-disabled}"
